<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="client.ui.ControladorLogin"
      stylesheets="@style.css"
      alignment="CENTER" spacing="12"
      prefWidth="360" prefHeight="480">
    <padding><Insets top="40" right="48" bottom="16" left="48"/></padding>

    <ImageView fitWidth="160" fitHeight="160" preserveRatio="true">
        <image><Image url="@../icon.png"/></image>
    </ImageView>

<VBox spacing="4" maxWidth="Infinity">
        <Label text="Usuário:" styleClass="campo-label"/>
        <TextField fx:id="campoUsuario"/>
        <Label text="Senha:" styleClass="campo-label"/>
        <PasswordField fx:id="campoSenha"/>
        <Label text="Status: Online" styleClass="label-online"/>
    </VBox>

    <HBox spacing="8">
        <Button fx:id="botaoLogin" text="Entrar" onAction="#aoFazerLogin"
                styleClass="button,primary"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        <Button fx:id="botaoCadastro" text="Cadastrar" onAction="#aoRegistrar"
                styleClass="button"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

    <Label fx:id="labelStatus" text="" styleClass="label-feedback"/>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox>
        <Label text="Esqueceu a sua senha?" styleClass="link-senha"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelServidor" text="Serviço: conectando..."
               styleClass="servidor-conectando"/>
    </HBox>

</VBox>
