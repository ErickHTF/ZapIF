<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.ui.ControladorChat"
            stylesheets="@style.css"
            prefWidth="860" prefHeight="560">

    <!-- Banner offline -->
    <top>
        <HBox fx:id="bannerOffline" visible="false" managed="false" alignment="CENTER">
            <Label text="Sem conexão — reconectando..."/>
        </HBox>
    </top>

    <!-- Barra lateral -->
    <left>
        <VBox fx:id="sidebar" minWidth="170" maxWidth="170">

            <!-- Perfil do usuário -->
            <HBox styleClass="perfil-header" alignment="CENTER" spacing="10">
                <ImageView fitWidth="36" fitHeight="36" preserveRatio="true">
                    <image><Image url="@../icon.png"/></image>
                </ImageView>
                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label fx:id="labelNomeUsuario" text=""/>
                    <Label text="(Online)" styleClass="label-online"/>
                </HBox>
            </HBox>

            <!-- Contador online -->
            <HBox styleClass="online-secao" alignment="CENTER_LEFT">
                <Label fx:id="labelTotalOnline" text="" styleClass="label-online-count"/>
            </HBox>

            <HBox styleClass="salas-header" alignment="CENTER_LEFT"
                  onMouseClicked="#aoAlternarSalas">
                <Label fx:id="labelSalas" text="SALAS" styleClass="label-secao"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelSetaSalas" text="▼" styleClass="label-seta"/>
            </HBox>

            <ListView fx:id="listaSalas" VBox.vgrow="ALWAYS"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text=" &lt; Início" onAction="#aoClicarInicio"
                    styleClass="botao-inicio"
                    maxWidth="1.7976931348623157E308"/>
        </VBox>
    </left>

    <!-- Área principal -->
    <center>
        <StackPane>

            <!-- Tela de boas-vindas (visível antes de selecionar uma sala) -->
            <VBox fx:id="painelBemVindo" alignment="CENTER" spacing="16">
                <ImageView fitWidth="96" fitHeight="96" preserveRatio="true">
                    <image><Image url="@../icon.png"/></image>
                </ImageView>
                <Label text="ZapIF" styleClass="boas-vindas-titulo"/>
                <Label text="Selecione uma sala para começar a conversar."
                       styleClass="boas-vindas-instrucao"/>
            </VBox>

            <!-- Área de chat (visível após selecionar uma sala) -->
            <VBox fx:id="painelChat" visible="false" managed="false"
                  maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
                <ListView fx:id="listaMensagens" VBox.vgrow="ALWAYS">
                    <padding><Insets top="8" right="12" bottom="4" left="12"/></padding>
                </ListView>

                <Separator/>

                <HBox styleClass="input-area" HBox.hgrow="ALWAYS">
                    <TextField fx:id="campoMensagem" HBox.hgrow="ALWAYS"
                               promptText="Mensagem..."
                               onKeyPressed="#aoPresionarTecla"/>
                    <Button fx:id="botaoEnviar" text="Enviar" onAction="#aoEnviar"
                            styleClass="button,primary"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
