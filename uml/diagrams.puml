@startuml diagrama_pacotes
title ZapIF — Diagrama de Pacotes e Arquitetura

skinparam packageStyle rectangle
skinparam linetype ortho

package "Máquina do Usuário" {

    package "client" <<Application>> {

        package "client.ui" {
            [ControladorLogin]
            [ControladorChat]
        }

        package "client.network" {
            [Conexao]
            [OuvinteMensagem]
            [OuvinteStatusConexao]
        }

        package "client.model" {
            [Mensagem]
            [Usuario]
        }

        [Main]
    }
}

package "Servidor (processo único)" {

    package "server" <<Application>> {
        [Servidor]
        [ManipuladorCliente]
        [Sala]
        [RegistroSessao]
        [BancoDados]
    }

    database "SQLite\nchat.db" as DB {
        [usuarios]
        [salas]
        [mensagens]
    }
}

' Dependências internas — cliente
[Main]              --> [Conexao]           : cria
[ControladorLogin]  --> [Conexao]           : usa
[ControladorChat]   --> [Conexao]           : usa
[ControladorLogin]  ..> [ControladorChat]   : abre
[ControladorChat]   ..> [Mensagem]          : instancia
[Conexao]           ..> [OuvinteMensagem]   : notifica
[Conexao]           ..> [OuvinteStatusConexao] : notifica

' Dependências internas — servidor
[Servidor]          --> [ManipuladorCliente] : submete ao pool
[ManipuladorCliente] --> [Sala]              : entra/sai
[ManipuladorCliente] --> [BancoDados]        : persiste/consulta
[ManipuladorCliente] --> [RegistroSessao]    : registra/libera
[Sala]              --> [ManipuladorCliente] : broadcast
[BancoDados]        --> DB                  : JDBC/SQLite

' Comunicação entre camadas
[Conexao] <--> [ManipuladorCliente] : TCP Socket\n(porta 5001)\nprotocolo texto "|"

@enduml
